---
import { ME } from '../../data/portfolio';
import NavBar from '../ui/NavBar.astro';
import Footer from '../ui/Footer.astro';

interface Props {
  title: string;
  description?: string;
  isArticlePage?: boolean;
  class?: string;
}

const { title, description = 'API and SDK documentation that developers understand and build with.', isArticlePage = false, class: className = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body class={className}>

<NavBar isArticlePage={isArticlePage} />

<slot />

<Footer />
</body>
</html>