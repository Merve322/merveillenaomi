---
import { ME } from '../../data/portfolio';

interface Props {
  pieces: { id: string }[];
}

const { pieces } = Astro.props;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-lines" aria-hidden="true"></div>
  <div class="hero-tag-row">
    <div class="hero-tag">API Documentation</div>
    <div class="hero-tag">SDK Guides</div>
    <div class="hero-tag">Developer Experience</div>
  </div>
  
  <div class="hero-project-count">
      <div class="hero-number" aria-hidden="true">{pieces.length}</div>
      <small>projects</small>
    </div>
   <!-- <aside class="hero-project-index" aria-label={`${pieces.length} projects featured`}>
    <div class="hero-project-label">Portfolio index</div>
    <div class="hero-project-count">
      <span>{String(pieces.length).padStart(2, '0')}</span>
      <small>projects</small>
    </div>
  </aside> -->
  <div class="hero-content">
    <div class="hero-label">Technical Writing Portfolio</div>
    <h1 set:html={ME.tagline} />
    <p class="hero-sub">{ME.subtagline}</p>
    <div class="hero-actions">
      <a href="#work-anchor" class="btn-dark">View selected work</a>
      <a href="#about-anchor" class="btn-outline">About me</a>
    </div>
  </div>
 <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>