---
interface Props {
  variant: 'dark' | 'outline';
  children: any;
  href?: string;
  class?: string;
}

const { variant, children, href, class: className = '' } = Astro.props;
const baseClass = variant === 'dark' ? 'btn-dark' : 'btn-outline';
const prefetch = Boolean(href?.startsWith('/'));
---

<a 
  href={href || '#'}
  class={`${baseClass} ${className}`.trim()}
  {...(prefetch ? { 'data-astro-prefetch': true } : {})}
>
  {children}
</a>