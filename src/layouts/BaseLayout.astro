---
import '../styles/styles.css';
import NavBar from '../components/ui/NavBar.astro';
import Footer from '../components/ui/Footer.astro';

interface Props {
  title: string;
  description?: string;
  isArticlePage?: boolean;
}

const {
  title,
  description = 'API and SDK documentation that developers understand and build with.',
  isArticlePage = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
<body>

<NavBar isArticlePage={isArticlePage} />

{isArticlePage ? (
  <div class="detail-wrapper">
    <slot />
  </div>
) : (
  <slot />
)}

<Footer />
</body>
</html>
